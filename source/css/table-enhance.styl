@import '_variables/variables'

// Markdown table surfaces
:root,
[color-mode='light']
  --table-header-bg #30323a
  --table-header-text #f8f8fa
  --table-surface #ffffff
  --table-row-alt #f7f7f8
  --table-border #e3e5e8
  --table-hover rgba(255, 112, 67, 0.08)
  --table-sort #ff7043
  --table-muted #8a8f98
  --table-scroll-thumb #a5a9b0
  --table-scroll-shadow rgba(31, 35, 41, 0.3)
  --table-floating-shadow rgba(15, 20, 26, 0.24)

[color-mode='dark']
  --table-header-bg #343943
  --table-header-text #f2f3f5
  --table-surface #252932
  --table-row-alt #292e37
  --table-border #3a404a
  --table-hover rgba(255, 112, 67, 0.12)
  --table-sort #ff8a65
  --table-muted #9ca3ad
  --table-scroll-thumb #626a76
  --table-scroll-shadow rgba(0, 0, 0, 0.58)
  --table-floating-shadow rgba(0, 0, 0, 0.52)

@media (prefers-color-scheme dark)
  :root:not([color-mode])
    --table-header-bg #343943
    --table-header-text #f2f3f5
    --table-surface #252932
    --table-row-alt #292e37
    --table-border #3a404a
    --table-hover rgba(255, 112, 67, 0.12)
    --table-sort #ff8a65
    --table-muted #9ca3ad
    --table-scroll-thumb #626a76
    --table-scroll-shadow rgba(0, 0, 0, 0.58)
    --table-floating-shadow rgba(0, 0, 0, 0.52)

// Responsive scroll surface
.table-wrapper
  position relative
  margin 1.5em 0
  overflow-x auto
  overflow-y visible
  border 1px solid var(--table-border)
  border-radius 10px
  background var(--table-surface)
  scrollbar-width thin
  scrollbar-color var(--table-scroll-thumb) transparent
  transition border-color 0.2s ease, box-shadow 0.2s ease
  -webkit-overflow-scrolling touch

  &.can-scroll-left:not(.can-scroll-right)
    box-shadow inset 14px 0 12px -14px var(--table-scroll-shadow)

  &.can-scroll-right:not(.can-scroll-left)
    box-shadow inset -14px 0 12px -14px var(--table-scroll-shadow)

  &.can-scroll-left.can-scroll-right
    box-shadow inset 14px 0 12px -14px var(--table-scroll-shadow), inset -14px 0 12px -14px var(--table-scroll-shadow)

  &:focus-visible
    outline 2px solid var(--table-sort)
    outline-offset 3px

  &::-webkit-scrollbar
    height 9px

  &::-webkit-scrollbar-track
    background transparent

  &::-webkit-scrollbar-thumb
    border 2px solid var(--table-surface)
    border-radius 999px
    background var(--table-scroll-thumb)

// Table layout and typography
.table-wrapper > table,
.post-content table,
.markdown-body table,
.content table,
article table
  position relative !important
  width 100% !important
  min-width 100% !important
  margin 0 !important
  border 0 !important
  border-collapse separate !important
  border-spacing 0 !important
  background var(--table-surface) !important
  color var(--color-text) !important
  font-family unquote(hexo-config('font.family') || 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif)
  font-size 0.95rem
  font-variant-numeric tabular-nums
  line-height 1.55

  caption
    padding 10px 14px
    color var(--table-muted)
    font-size 0.85em
    text-align left

  thead
    position relative
    z-index 10

    &.is-floating
      filter drop-shadow(0 7px 7px var(--table-floating-shadow))
      will-change transform

    th
      padding 13px 16px !important
      border 0 !important
      border-right 1px solid rgba(255, 255, 255, 0.2) !important
      border-bottom 1px solid var(--table-border) !important
      background var(--table-header-bg) !important
      color var(--table-header-text) !important
      font-weight 600 !important
      letter-spacing 0.02em
      text-align left
      user-select none
      vertical-align middle

      &:last-child
        border-right 0 !important

      &[align='center']
        text-align center

      &[align='right']
        text-align right

      &.sortable
        cursor pointer

        &::after
          content ' ↕'
          margin-left 6px
          color var(--table-muted)
          font-size 0.82em
          opacity 0.55
          transition color 0.2s ease, opacity 0.2s ease

        &:hover::after,
        &:focus-visible::after
          color var(--table-header-text)
          opacity 0.9

      &.sort-asc::after
        content ' ↑'
        color var(--table-sort)
        opacity 1

      &.sort-desc::after
        content ' ↓'
        color var(--table-sort)
        opacity 1

      &:focus-visible
        position relative
        z-index 11
        outline 2px solid var(--table-sort)
        outline-offset -3px

  tbody
    tr
      background var(--table-surface)
      transition background-color 0.2s ease

      &:nth-child(even)
        background var(--table-row-alt)

      &:hover
        background var(--table-hover)

      &:last-child td
        border-bottom 0 !important

    td
      padding 12px 16px !important
      border 0 !important
      border-right 1px solid var(--table-border) !important
      border-bottom 1px solid var(--table-border) !important
      color var(--color-text) !important
      text-align left
      vertical-align middle
      overflow-wrap anywhere

      &:last-child
        border-right 0 !important

      &[align='center']
        text-align center

      &[align='right']
        text-align right

@media (max-width 768px)
  .table-wrapper
    margin 1.25em 0
    border-radius 8px

  .table-wrapper > table,
  .post-content table,
  .markdown-body table,
  .content table,
  article table
    width max-content !important
    font-size 0.88rem

    thead th
      padding 11px 12px !important
      white-space nowrap

    tbody td
      min-width 96px
      max-width 280px
      padding 10px 12px !important
      white-space normal

@media (prefers-reduced-motion reduce)
  .table-wrapper,
  .table-wrapper table th::after,
  .table-wrapper table tbody tr
    transition none !important
