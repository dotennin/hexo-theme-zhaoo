.index-section
  max-width $content-width-index
  margin 0 auto
  padding-top 30px
  .index-header
    display flex
    align-items flex-end
    justify-content space-between
    padding 0 15px 18px
    > div p
      margin 0 0 4px
      color var(--color-text-third)
      font-size 0.72rem
      font-weight 600
      letter-spacing 0.16em
      text-transform uppercase
    h2
      margin 0
      color var(--color-text)
      font-family $font-family-reading
      font-size clamp(1.65rem, 3vw, 2.15rem)
      font-weight 600
    > a
      padding 8px 0
      color $color-link
      font-size 0.9rem
      &:focus-visible
        outline 2px solid $color-link
        outline-offset 4px
  @media (max-width 576px)
    padding-top 22px
    .index-header
      padding 0 15px 14px

.post
  .post-item
    display flex
    margin-bottom 30px
    .post-wrap
      display flex
      width 100%
      flex-direction column
      overflow hidden
      border 1px solid var(--color-border)
      border-radius $radius-md
      box-shadow $shadow-card
      background-color var(--color-surface)
      transition transform 0.25s ease, box-shadow 0.25s ease
      .post-top
        z-index 10
        width 80px
        height 80px
        overflow hidden
        position absolute
        top 0
        div
          line-height 18px
          text-align center
          -webkit-transform rotate(-45deg)
          -moz-transform rotate(-45deg)
          -ms-transform rotate(-45deg)
          -o-transform rotate(-45deg)
          position relative
          padding 3px 0
          top 10px
          left -28px
          width 100px
          background-color $color-link
          background-image $color-link-gradient
          color #ffffff
          box-shadow -3px 5px 6px -5px rgba(0, 0, 0, 0.5)
      .post-image
        display block
        position relative
        width 100%
        height 0
        padding-bottom 58%
        img
          position absolute
          top 0
          left 0
          width 100%
          height 100%
          overflow hidden
          object-fit cover
          &, &:hover
            transition $transition
          &:hover
            filter grayscale(100%)
        .post-label
          position absolute
          left 12px
          bottom 12px
          z-index 2
          max-width calc(100% - 24px)
          overflow hidden
          padding 5px 10px
          border 1px solid rgba(255, 255, 255, 0.28)
          border-radius 999px
          color #ffffff
          background rgba(10, 16, 22, 0.62)
          -webkit-backdrop-filter blur(8px)
          backdrop-filter blur(8px)
          font-size 0.72rem
          line-height 1.2
          text-overflow ellipsis
          white-space nowrap
      .post-content
        display flex
        flex 1
        flex-direction column
        padding 18px
        &-wrap
          flex 1
        .post-title
          margin-bottom 10px
          font-family $font-family-reading
          font-size 1.25rem
          font-weight 600
          line-height 1.35
          a
            display -webkit-box
            -webkit-box-orient vertical
            -webkit-line-clamp 2
            overflow hidden
        .post-excerpt
          p
            display -webkit-box
            overflow hidden
            margin-bottom 14px
            color var(--color-text-secondary)
            font-size 0.9rem
            line-height 1.65
            -webkit-box-orient vertical
            -webkit-line-clamp 3
            if (hexo-config('indent.excerpt'))
              text-indent unquote(hexo-config('indent.excerpt'))
        .post-info
          margin-top auto
          color var(--color-text-third)
          font-size 0.8rem
          .post-info-item
            margin-right 10px
            i
              font-size 1em
              margin-right 5px

@media (hover hover) and (pointer fine)
  .post .post-item .post-wrap:hover
    transform translateY(-4px)
    box-shadow $shadow-card-active
