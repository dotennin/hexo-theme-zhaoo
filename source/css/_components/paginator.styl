.paginator
  text-align center
  margin-bottom 30px
  span, a
    display inline-block
    margin 0 3px
    width 38px
    height 38px
    line-height 38px
    border-radius $radius-sm
  span, a:hover
    background-color var(--color-text)
    color var(--color-background)
  .space
    color var(--color-text)
    background-color rgba(0, 0, 0, 0)
  a:focus-visible
    outline 2px solid $color-link
    outline-offset 2px
