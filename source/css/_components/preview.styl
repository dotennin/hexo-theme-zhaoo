@keyframes move-forever
  0%
    transform translate3d(-90px, 0, 0)
  100%
    transform translate3d(85px, 0, 0)
@keyframes blink
  0%
    opacity 1
  50%
    opacity 0
  100%
    opacity 1
.preview
  .preview-image
    z-index 40
    height 44vh
    height clamp(340px, 44svh, 520px)
    min-height 340px
    width 100%
    background-image var(--background-image)
    background-repeat no-repeat
    background-size unquote(hexo-config('preview.background.size') || '100% 100%')
    background-position unquote(hexo-config('preview.background.position') || center)
    background-attachment local
    position relative
    display flex
    justify-content center
    align-items center
    &::before
      content ''
      position absolute
      inset 0
      z-index 1
      background linear-gradient(180deg, rgba(6, 12, 18, 0.12), var(--color-overlay))
    .preview-video
      object-fit cover
      width 100%
      height 100%
    .preview-overlay
      position absolute
      bottom -1px
      left -100vw
      right 0
      z-index 50
      filter drop-shadow(var(--color-background) 100vw 0px)
      .preview-waves
        position relative
        width 100%
        height 15vh
        margin-bottom -7px
        min-height 100px
        max-height 150px
        @media (max-width 768px)
          height 40px
          min-height 40px
      .preview-parallax
        > use
          animation move-forever 25s cubic-bezier(0.55, 0.5, 0.45, 0.5) infinite
        > use:nth-child(1)
          animation-delay -2s
          animation-duration 7s
        > use:nth-child(2)
          animation-delay -3s
          animation-duration 10s
        > use:nth-child(3)
          animation-delay -4s
          animation-duration 13s
        > use:nth-child(4)
          animation-delay -5s
          animation-duration 20s
  .preview-content
    position relative
    z-index 60
    width min(90%, 820px)
    padding 32px $page-gutter 58px
    text-align center
    color #ffffff
  .preview-eyebrow
    margin 0 0 10px
    color rgba(255, 255, 255, 0.82)
    font-size clamp(0.72rem, 1.6vw, 0.92rem)
    font-weight 600
    letter-spacing 0.2em
    text-transform uppercase
  .preview-title
    margin 0
    color #ffffff
    font-family $font-family-reading
    font-size clamp(2.4rem, 7vw, 4.8rem)
    font-weight 600
    line-height 1
    letter-spacing -0.035em
    text-shadow 0 3px 22px rgba(0, 0, 0, 0.28)
  .preview-motto-wrapper
    display flex
    align-items baseline
    justify-content center
    min-height 52px
    margin-top 18px
    .preview-motto
      max-width 680px
      margin 0
      color convert(hexo-config('preview.motto.color')) || #ffffff
      font-family $font-family-reading
      font-size clamp(1rem, 2.4vw, 1.5rem)
      font-weight 400
      line-height 1.7
    .preview-cursor
      font-size clamp(1rem, 2.4vw, 1.5rem)
      color #ffffff
      animation blink 0.7s infinite
  .preview-cta
    display inline-flex
    align-items center
    gap 8px
    min-height $hit-target
    margin-top 12px
    padding 9px 20px
    border 1px solid rgba(255, 255, 255, 0.62)
    border-radius 999px
    color #ffffff
    background rgba(8, 14, 20, 0.16)
    font-size 0.9rem
    letter-spacing 0.04em
    &:hover
      color #ffffff
      border-color #ffffff
      background rgba(255, 255, 255, 0.14)
    &:focus-visible
      outline 2px solid #ffffff
      outline-offset 3px

@media (max-width 768px)
  .preview
    .preview-image
      height 42vh
      height clamp(320px, 42svh, 420px)
      min-height 320px
      .preview-overlay .preview-waves
        height 40px
        min-height 40px
    .preview-content
      padding-bottom 48px
    .preview-title
      font-size clamp(2.2rem, 13vw, 3.5rem)
    .preview-motto-wrapper
      min-height 58px
      margin-top 14px

@media (prefers-reduced-motion reduce)
  .preview
    .preview-parallax > use
      animation none !important
    .preview-cursor
      animation none !important
